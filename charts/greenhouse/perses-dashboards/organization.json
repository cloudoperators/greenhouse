      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "Organization",
            "description": "Organization",
            "hidden": false
          },
          "defaultValue": "sci-demo",
          "allowAllValue": false,
          "allowMultiple": false,
          "sort": "alphabetical-asc",
          "plugin": {
            "kind": "PrometheusLabelValuesVariable",
            "spec": {
